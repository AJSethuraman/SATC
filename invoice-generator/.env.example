# Copy this file to .env and fill in your own values.

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
APP_BASE_URL=http://localhost:5000
# Set to "production" when hosting over HTTPS (enables secure cookies).
APP_ENV=development

# Database. Default is local SQLite; set to a Postgres URL in production
# (e.g. postgres://user:pass@host:5432/dbname).
# DATABASE_URL=

# Error monitoring (optional): paste a Sentry DSN to capture exceptions.
SENTRY_DSN=

# Email confirmation: auto (enforce only once SMTP is set) | always | never
REQUIRE_EMAIL_VERIFICATION=auto

# Rate-limit storage. memory:// is fine for one instance; use a redis:// URL
# if you run multiple instances so limits are shared.
RATELIMIT_STORAGE_URI=memory://

# --- Monetization (built but OFF by default; turn on when ready) ---
# Platform fee per payment via Stripe Connect (0 = no fee).
PLATFORM_FEE_PERCENT=0
PLATFORM_FEE_FLAT_CENTS=0
# Subscription tiers / paywall (false = everything free, no limits enforced).
BILLING_ENABLED=false

# The JSON API uses a per-user key shown on the Account page (no env var).

# Stripe (test mode keys start with sk_test_ / whsec_)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP / email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FROM_EMAIL=
