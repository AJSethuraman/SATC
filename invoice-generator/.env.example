# Copy this file to .env and fill in your own values.

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
APP_BASE_URL=http://localhost:5000

# JSON REST API. Leave blank to keep the /api/* endpoints disabled.
# Set to any strong random string; clients send it as the X-API-Key header.
API_KEY=

# Stripe (test mode keys start with sk_test_ / whsec_)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP / email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FROM_EMAIL=
